{
  "name": "codex-feishu-bridge-windows",
  "version": "1.0.0",
  "description": "Feishu to Codex bridge for Windows",
  "main": "src/bridge.js",
  "type": "commonjs",
  "scripts": {
    "bridge": "node src/bridge.js",
    "bridge:start": "powershell -ExecutionPolicy Bypass -File scripts/bridge-start.ps1",
    "bridge:stop": "powershell -ExecutionPolicy Bypass -File scripts/bridge-stop.ps1",
    "bridge:status": "powershell -ExecutionPolicy Bypass -File scripts/bridge-status.ps1",
    "bridge:logs": "powershell -ExecutionPolicy Bypass -File scripts/bridge-logs.ps1",
    "mirror:view": "powershell -ExecutionPolicy Bypass -File scripts/mirror-view.ps1 latest 60"
  },
  "dependencies": {
    "@larksuite/cli": "^1.0.4"
  }
}
